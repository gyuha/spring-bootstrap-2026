# =============================================================================
# Docker Compose 환경변수 예시 파일
# 이 파일을 .env 로 복사한 후 값을 수정하세요.
#   cp .env.example .env
# .env 파일은 .gitignore에 포함되어야 합니다.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=bootstrap
POSTGRES_USER=bootstrap
POSTGRES_PASSWORD=bootstrap

# ── JWT ───────────────────────────────────────────────────────────────────────
# 운영 환경에서는 반드시 32자 이상의 강력한 시크릿 키로 변경하세요.
JWT_SECRET=bootstrap-secret-key-change-in-production-must-be-32-chars

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
